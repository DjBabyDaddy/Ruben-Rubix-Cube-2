# --- API KEYS ---
# Required: Claude powers RUBE's cognitive engine
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Alternative LLM routing
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional: Web search (SerpAPI)
SERPAPI_API_KEY=your_serpapi_key_here

# Optional: Text-to-speech (Cartesia — not currently used, Kokoro is default)
CARTESIA_API_KEY=your_cartesia_key_here

# Optional: Fast LLM for search readouts and analytics formatting
GROQ_API_KEY=your_groq_key_here

# Optional: News headlines
NEWS_API_KEY=your_newsapi_key_here

# Optional: Sports odds data
ODDS_API_API_KEY=your_odds_api_key_here

# Optional: n8n webhook for social media posting and analytics
N8N_WEBHOOK_URL=your_n8n_webhook_url_here
N8N_ANALYTICS_WEBHOOK_URL=your_n8n_analytics_webhook_url_here

# --- SYSTEM PATHS ---
PROMPT_PATH=core/prompt.txt
MEMORY_PATH=memory/memory.json

# --- SETTINGS ---
LOG_LEVEL=INFO
