# ============================================================
# RUBE Environment Configuration
# Copy this to .env and fill in your keys
# Or run: python setup_wizard.py
# ============================================================

# === Required ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# === Voice: Text-to-Speech ===
# Provider: cartesia | elevenlabs | edge_tts
TTS_PROVIDER=cartesia
TTS_API_KEY=your_tts_api_key_here
TTS_VOICE_ID=default

# === Voice: Speech-to-Text ===
# Provider: deepgram | disabled
STT_PROVIDER=deepgram
STT_API_KEY=your_stt_api_key_here

# === Optional: Search ===
SERPAPI_API_KEY=your_serpapi_key_here
EXA_API_KEY=your_exa_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# === Optional: Social Media / Analytics ===
N8N_WEBHOOK_URL=your_n8n_webhook_url_here
N8N_ANALYTICS_WEBHOOK_URL=your_n8n_analytics_webhook_url_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=
FACEBOOK_ACCESS_TOKEN=

# === Optional: News / Sports ===
NEWS_API_KEY=your_newsapi_key_here
ODDS_API_API_KEY=your_odds_api_key_here

# === Optional: User-added API keys ===
# ELEVENLABS_API_KEY=your_elevenlabs_key_here
# OPENROUTER_API_KEY=your_openrouter_key_here

# === Feature Flags ===
FEATURE_DESKTOP_AUTOMATION=true
FEATURE_BROADCAST_CONTROL=false
FEATURE_FACIAL_RECOGNITION=false
FEATURE_SOCIAL_MEDIA=false

# === Remote Updates ===
RUBE_INSTANCE_ID=
RUBE_UPDATE_SERVER=
RUBE_AUTO_UPDATE=true

# === System Paths ===
PROMPT_PATH=core/prompt.txt
MEMORY_PATH=memory/memory.json
LOG_LEVEL=INFO
